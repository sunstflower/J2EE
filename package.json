{
  "name": "mac-proxy-client",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo for a macOS proxy client with Electron, React, and Spring Boot.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @mac-proxy-client/web",
    "build:web": "npm run build --workspace @mac-proxy-client/web",
    "dev:desktop": "npm run dev --workspace @mac-proxy-client/desktop",
    "build:local-api": "mvn -q -DskipTests package --file services/local-api/pom.xml",
    "vendor:core": "zsh ./scripts/vendor_clash_meta.sh",
    "import:core": "zsh ./scripts/import_clash_meta.sh",
    "prepare:desktop-bundle": "zsh ./scripts/prepare_desktop_bundle.sh",
    "build:desktop": "npm run build --workspace @mac-proxy-client/desktop",
    "dist:desktop": "npm run dist --workspace @mac-proxy-client/desktop",
    "docs:check": "echo \"Documentation-first initialization: no automated doc checks yet.\""
  }
}
